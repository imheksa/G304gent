# 6304 Agent — environment variables (set these in Vercel → Project → Settings → Environment Variables)

# --- Public (client) ---
# Privy App ID (already has a hardcoded default in code; override here if needed)
NEXT_PUBLIC_PRIVY_APP_ID=
# Solana wallet that receives payments (hardcoded default exists; override if needed)
NEXT_PUBLIC_RECIPIENT_WALLET=
# Optional custom Solana mainnet RPC (defaults to a public node)
NEXT_PUBLIC_SOLANA_RPC_URL=
# Set to "1" to use the Supabase backend instead of localStorage
NEXT_PUBLIC_USE_BACKEND=1
# Set to "1" to power the dashboard with real AI scans (needs ANTHROPIC_API_KEY)
NEXT_PUBLIC_AI_ENABLED=1

# --- Server only (never exposed to the browser) ---
# Privy App Secret — Privy dashboard → App settings → "App secret"
PRIVY_APP_SECRET=
# Supabase — Project settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# OpenRouter API key — one key, many engines; powers the AI-visibility scans
# (https://openrouter.ai/keys). The scan queries GPT, Gemini, Claude, Grok &
# Deepseek and a judge model scores them.
OPENROUTER_API_KEY=
# (optional) override engine→model slugs, e.g. {"Grok":"x-ai/grok-2"}
OPENROUTER_ENGINE_MODELS=
# (optional) judge model slug (default openai/gpt-4o-mini)
OPENROUTER_JUDGE_MODEL=
# --- Distribute → Wikidata OAuth (optional; enables one-click "Connect Wikidata
# account" so users don't need a bot password). Register an OAuth 2.0 consumer at
# https://meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration with callback
# https://YOUR_DOMAIN/api/distribute/wikidata/callback and grants to create/edit
# pages. If unset, the Distribute UI falls back to bot-password login.
WIKIDATA_OAUTH_CLIENT_ID=
WIKIDATA_OAUTH_CLIENT_SECRET=
