# Privy + Solana payments configuration (all public, client-side values).
# In production these are set as GitHub Actions repository Variables, not secrets.

# Privy App ID from https://home.privy.io/apps
NEXT_PUBLIC_PRIVY_APP_ID=

# Solana wallet address that receives SOL / USDC / USDT payments
NEXT_PUBLIC_RECIPIENT_WALLET=

# Optional: custom Solana mainnet RPC (defaults to the public endpoint)
NEXT_PUBLIC_SOLANA_RPC_URL=
